#!/usr/bin/env bash
#
# Sync .serena folder from a git worktree back to the main repo
# In case of conflicts, keeps the file with the newer modified date
#

set -euo pipefail

main() {
  # Check if we're in a git repo
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: Not in a git repository" >&2
    exit 1
  fi

  local current_worktree
  current_worktree="$(git rev-parse --show-toplevel)"

  # Find the main worktree (first one in the list, marked with 'bare' or no branch)
  local main_worktree
  main_worktree="$(git worktree list --porcelain | grep -m 1 '^worktree ' | cut -d' ' -f2)"

  if [[ "$current_worktree" == "$main_worktree" ]]; then
    echo "Already in main worktree: $main_worktree"
    echo "Nothing to sync."
    exit 0
  fi

  local source_serena="$current_worktree/.serena"
  local dest_serena="$main_worktree/.serena"

  # Check if source .serena folder exists
  if [[ ! -d "$source_serena" ]]; then
    echo "No .serena folder found in current worktree: $current_worktree"
    exit 0
  fi

  echo "Syncing .serena from worktree to main repo..."
  echo "  From: $source_serena"
  echo "  To:   $dest_serena"
  echo

  # Create destination directory if it doesn't exist
  mkdir -p "$dest_serena"

  # Use rsync with:
  #   -a: archive mode (preserve permissions, timestamps, etc.)
  #   -v: verbose
  #   -u: update (skip files that are newer on receiver)
  #   --itemize-changes: show what's being updated
  rsync -avu --itemize-changes "$source_serena/" "$dest_serena/"

  echo
  echo "✨ Sync complete!"
}

main "$@"
